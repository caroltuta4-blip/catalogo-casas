<span typeof="mw:Entity">&nbsp;</span></td></tr><tr><th scope="row" class="label" style="text-align:left;border:0;padding:1px 7px;font-weight:100;"><span typeof="mw:Entity">&nbsp;</span>• Total</th><td colspan="2" style="border:0;padding:1px 7px 1px 1px;">
196&nbsp;758<span typeof="mw:Entity">&nbsp;</span>hab.<sup about="#mwt9" class="mw-ref reference" id="cite_ref-Censo_2-0" rel="dc:references" typeof="mw:Extension/ref" data-mw="{&quot;name&quot;:&quot;ref&quot;,&quot;attrs&quot;:{&quot;name&quot;:&quot;Censo&quot;},&quot;body&quot;:{&quot;id&quot;:&quot;mw-reference-text-cite_note-Censo-2&quot;}}"><a href="#cite_note-Censo-2" id="mwHw"><span class="mw-reflink-text" id="mwIA"><span class="cite-bracket" id="mwIQ">[</span>2<span class="cite-bracket" id="mwIg">]</span></span></a></sup></td></tr><tr><th scope="row" class="label" style="text-align:left;border:0;padding:1px 7px;font-weight:100;"><span typeof="mw:Entity">&nbsp;</span>• <a rel="mw:WikiLink" href="//es.wikipedia.org/wiki/Densidad_de_población" title="Densidad de población">Densidad</a></th><td colspan="2" style="border:0;padding:1px 7px 1px 1px;">
