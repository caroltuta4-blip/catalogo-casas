</section></section><section data-mw-section-id="15" id="mwAaY" aria-labelledby="Corregimientos"><div class="mw-heading mw-heading3"><h3 id="Corregimientos">Corregimientos</h3><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="//es.wikipedia.org/w/index.php?title=Yopal&amp;action=edit&amp;section=15" title="Editar sección: Corregimientos"><span>editar</span></a><span class="mw-editsection-bracket">]</span></span></div>
